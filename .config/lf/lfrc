cmd newtex ${{
	# todo: ivconv & ignore spaces
	filename=$( echo "$2" | sed 's/\.tex//' )
	cp ~/.local/share/templates/$1.tex "$filename.tex"
	$EDITOR "$filename.tex"
}}

cmd newc ${{
	filename=$( echo "$1" | sed 's/\.c//' )
	cp ~/.local/share/templates/c.c "$filename.c"
	$EDITOR "$filename.c"
}}

cmd newterm &{{
	# https://stackoverflow.com/questions/19302913/exit-zsh-but-leave-running-jobs-open
	#nohup st & disown
	nohup st
}}

map t newterm

