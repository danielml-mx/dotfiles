# Opening files:
# If it is an image, use the special sxiv command
# else handle with xdg-open.
cmd open &{{
    test -L "$f" && f=$(readlink -f "$f")
    case $(file --mime-type "$f" -b) in
        image/vnd.djvu) xdg-open "$fx" ;;							# open as same process (good for term swallowing)
        image/*) sxiv "$fx" 	;;
        *) xdg-open "$fx" ;;							# open as same process (good for term swallowing)
        #*) for f in "$fx"; do xdg-open "$f" > /dev/null 2> /dev/null & done;;	# open as different 
    esac
}}

